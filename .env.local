NEXTAUTH_URL=http://localhost:3000

# JWT Configuration (REQUIRED - Use Supabase JWT Signing Keys)
# Go to Supabase Dashboard → Authentication → Settings → JWT Settings
# Copy the JWT Signing Public Key (not the legacy secret)
NEXT_PUBLIC_SUPABASE_JWT_PUBLIC_KEY=your_jwt_signing_public_key_here
# Remove JWT_SECRET and NEXTAUTH_SECRET - we'll use Supabase JWT directly

# Security (REQUIRED)
ENCRYPTION_KEY=your_32_character_encryption_key

# Rate Limiting (OPTIONAL - defaults provided)
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# Code Generation (OPTIONAL - defaults provided)
CODE_LENGTH=8
CODE_EXPIRY_MINUTES=5

# Storage (REQUIRED)
SUPABASE_STORAGE_BUCKET=receipts
SUPABASE_STORAGE_URL=https://hagkgejtlnpgdfbaztgz.supabase.co/storage/v1

# Development (OPTIONAL)
NODE_ENV=development
DEBUG=false
LOG_LEVEL=info
