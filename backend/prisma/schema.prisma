generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Model untuk Initial Build - Tanpa autentikasi user
model Referral {
  id            String   @id @default(uuid())
  referralCode  String   @unique // Kode referral statis untuk demo
  inviteePhone  String?  // Optional untuk Initial Build
  status        ReferralStatus @default(PENDING)
  rewardCode    String?  @unique // Kode unik untuk klaim hadiah
  claimedAt     DateTime?
  redeemedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relasi ke reward code
  rewardCodeRef RewardCode?

  @@map("referrals")
}

model Reward {
  id              String   @id @default(uuid())
  name            String   // Nama hadiah (e.g., "Gratis Es Kopi")
  description     String   // Deskripsi hadiah
  pointsRequired  Int      @default(0) // Untuk Initial Build, semua hadiah gratis
  category        RewardCategory @default(INSTANT)
  isActive        Boolean  @default(true)
  stockQuantity   Int      @default(100)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relasi ke reward codes
  rewardCodes     RewardCode[]

  @@map("rewards")
}

model RewardCode {
  id         String   @id @default(uuid())
  code       String   @unique // Kode unik acak (e.g., X7G9P2)
  rewardId   String
  referralId String   @unique
  status     RewardCodeStatus @default(ACTIVE)
  expiresAt  DateTime // Timer 15 menit
  usedAt     DateTime?
  createdAt  DateTime @default(now())

  // Relasi
  reward     Reward   @relation(fields: [rewardId], references: [id])
  referral   Referral @relation(fields: [referralId], references: [id])

  @@map("reward_codes")
}

model ClaimedReward {
  id          String   @id @default(uuid())
  rewardCode  String   @unique // Referensi ke RewardCode.code
  rewardName  String   // Nama hadiah yang diklaim
  claimedAt   DateTime @default(now())
  redeemedAt  DateTime?
  cashierId   String?  // ID kasir yang memverifikasi
  storeId     String?  // ID toko
  notes       String?  // Catatan kasir
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("claimed_rewards")
}

// Enums
enum ReferralStatus {
  PENDING    // Referral dibuat, belum diklaim
  CLAIMED    // Hadiah diklaim oleh invitee
  REDEEMED   // Hadiah ditukar di toko
  EXPIRED    // Referral/hadiah expired
}

enum RewardCategory {
  INSTANT     // Hadiah instan untuk referral
  MILESTONE   // Hadiah milestone (untuk Phase 2)
  SEASONAL    // Hadiah musiman (untuk Phase 2)
}

enum RewardCodeStatus {
  ACTIVE      // Kode aktif dan bisa digunakan
  USED        // Kode sudah digunakan
  EXPIRED     // Kode expired (timer habis)
}


